generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String                  @id @default(uuid())
  email                    String                  @unique
  name                     String?
  packageId                String                  @map("package_id")
  role                     String                  @default("user")
  accountApprovedAt        DateTime?               @map("account_approved_at")
  failedLoginAttempts      Int                     @default(0) @map("failed_login_attempts")
  lockedUntil              DateTime?               @map("locked_until")
  lastLoginAt              DateTime?               @map("last_login_at")
  createdAt                DateTime                @default(now()) @map("created_at")
  goals                    Json?
  interests                Json?
  notificationPrefs        Json?                   @map("notification_prefs")
  onboardingCompleted      Boolean                 @default(false) @map("onboarding_completed")
  termsAcceptedAt          DateTime?               @map("terms_accepted_at")
  privacyAcceptedAt        DateTime?               @map("privacy_accepted_at")
  medicalConsentAcceptedAt DateTime?               @map("medical_consent_accepted_at")
  legalConsentVersion      String?                 @map("legal_consent_version")
  legalConsentIp           String?                 @map("legal_consent_ip")
  legalConsentUserAgent    String?                 @map("legal_consent_user_agent")
  subscriptionExpiresAt    DateTime?               @map("subscription_expires_at")
  couponUsed               String?                 @map("coupon_used")
  cases                    Case[]
  notes                    Note[]
  orgAiUsage               OrgAiUsage[]
  orgMemberships           OrgMember[]
  patients                 Patient[]
  pomodoroLogs             PomodoroLog[]
  orgAdmin                 ResearchOrganization[]  @relation("OrgAdmin")
  sessions                 Session[]
  userModules              UserModule[]
  package                  Package                 @relation(fields: [packageId], references: [id])
  learningProfile          StudentLearningProfile?
  questionAttempts         QuestionAttempt[]
  tokenWallet              TokenWallet?
  tokenTransactions        TokenTransaction[]
  dashboardPreferences     DashboardPreferences?
  studySessions            StudySession[]
  addonAccesses            UserAddonAccess[]       @relation("UserAddonAccessUser")
  grantedAddonAccesses     UserAddonAccess[]       @relation("UserAddonAccessGrantedBy")
  supportTickets           SupportTicket[]         @relation("SupportTicketOwner")
  assignedSupportTickets   SupportTicket[]         @relation("SupportTicketAssignedAdmin")
  supportTicketMessages    SupportTicketMessage[]  @relation("SupportTicketMessageAuthor")
  supportTicketNotesAuthored SupportTicketNote[]   @relation("SupportTicketNoteAuthor")
  supportTicketAuditsAuthored SupportTicketAudit[] @relation("SupportTicketAuditActor")
  academicProfile          UserAcademicProfile?
  communitySpacesOwned     CommunitySpace[]        @relation("CommunitySpaceOwner")
  communityThreadsAuthored CommunityThread[]       @relation("CommunityThreadAuthor")
  communityPostsAuthored   CommunityPost[]         @relation("CommunityPostAuthor")
  communityResourcesAuthored CommunityResource[]   @relation("CommunityResourceAuthor")
  communityReactions       CommunityReaction[]
  communityBookmarks       CommunityBookmark[]
  communityFollows         CommunityFollow[]
  communityChatsCreated    CommunityGroupChat[]    @relation("CommunityChatCreator")
  communityChatMemberships CommunityChatMember[]
  communityChatMessages    CommunityChatMessage[]  @relation("CommunityChatMessageAuthor")
  communityMessageReads    CommunityMessageRead[]
  communityReportsFiled    CommunityReport[]       @relation("CommunityReportReporter")
  communityReportsAssigned CommunityReport[]       @relation("CommunityReportModerator")
  communityModerationActionsAuthored CommunityModerationAction[] @relation("CommunityModerationActor")
  communityRoleAssignments CommunityRoleAssignment[] @relation("CommunityRoleAssignee")
  communityRoleAssignmentsGranted CommunityRoleAssignment[] @relation("CommunityRoleGrantor")
  communityBlocksInitiated CommunityBlock[]        @relation("CommunityBlocker")
  communityBlocksReceived  CommunityBlock[]        @relation("CommunityBlocked")
  communityMutes           CommunityMute[]         @relation("CommunityMuteUser")
  communityMuteTargets     CommunityMute[]         @relation("CommunityMutedUser")
  communityBansReceived    CommunityBan[]          @relation("CommunityBannedUser")
  communityBansIssued      CommunityBan[]          @relation("CommunityBanActor")
  communityNotifications   CommunityNotification[]
  moduleActivities         ModuleActivity[]

  @@map("users")
}

model Package {
  id           String          @id @default(uuid())
  name         String          @unique
  dailyAiLimit Int             @map("daily_ai_limit")
  price        Float
  tokenGrant   BigInt          @default(0) @map("token_grant")
  modules      PackageModule[]
  users        User[]
  coupons      CouponCode[]

  @@map("packages")
}

model Module {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  orgModules     OrgModule[]
  packageModules PackageModule[]
  userModules    UserModule[]

  @@map("modules")
}

model UserModule {
  userId   String @map("user_id")
  moduleId String @map("module_id")
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@map("user_modules")
}

model PackageModule {
  packageId String  @map("package_id")
  moduleId  String  @map("module_id")
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@id([packageId, moduleId])
  @@map("package_modules")
}

model Patient {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  noteField    String?  @map("notes")
  createdAt    DateTime @default(now()) @map("created_at")
  cases        Case[]
  patientNotes Note[]   @relation("PatientNotes")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patients")
}

model Case {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  patientId   String?   @map("patient_id")
  title       String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  patient     Patient?  @relation(fields: [patientId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    Session[]

  @@map("cases")
}

model Session {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  caseId     String?  @map("case_id")
  model      String
  tokensUsed Int      @map("tokens_used")
  createdAt  DateTime @default(now()) @map("created_at")
  case       Case?    @relation(fields: [caseId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Note {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  patientId String?  @map("patient_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  patient   Patient? @relation("PatientNotes", fields: [patientId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model PomodoroLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  duration    Int
  completedAt DateTime @default(now()) @map("completed_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pomodoro_logs")
}

/// Bilimsel araştırma organizasyonu. Süper admin tarafından oluşturulur.
/// Her org bir org_admin'e ve süreli erişime sahiptir.
model ResearchOrganization {
  id                String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  slug              String          @unique
  adminUserId       String          @map("admin_user_id")
  status            String          @default("active")
  startsAt          DateTime        @map("starts_at") @db.Timestamptz(6)
  expiresAt         DateTime        @map("expires_at") @db.Timestamptz(6)
  markupPct         Float           @default(30) @map("markup_pct")
  monthlyBudgetUsd  Float?          @map("monthly_budget_usd")
  alertThresholdPct Int             @default(80) @map("alert_threshold_pct")
  notes             String?
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  aiUsage           OrgAiUsage[]
  invitations       OrgInvitation[]
  members           OrgMember[]
  modules           OrgModule[]
  adminUser         User            @relation("OrgAdmin", fields: [adminUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("research_organizations")
}

/// Bir organizasyona üye kullanıcı. role: "org_admin" | "researcher"
model OrgMember {
  id       String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  orgId    String               @map("org_id")
  userId   String               @map("user_id")
  role     String               @default("researcher")
  isActive Boolean              @default(true) @map("is_active")
  joinedAt DateTime             @default(now()) @map("joined_at") @db.Timestamptz(6)
  org      ResearchOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([orgId, userId])
  @@index([userId], map: "idx_org_members_user_id")
  @@map("org_members")
}

/// Bir organizasyona açık olan modüller
model OrgModule {
  orgId    String               @map("org_id")
  moduleId String               @map("module_id")
  module   Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  org      ResearchOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([orgId, moduleId])
  @@map("org_modules")
}

/// Araştırmacıların yaptığı her AI sorgusunun maliyeti
model OrgAiUsage {
  id           String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  orgId        String               @map("org_id")
  userId       String               @map("user_id")
  module       String?
  model        String
  inputTokens  Int                  @default(0) @map("input_tokens")
  outputTokens Int                  @default(0) @map("output_tokens")
  costUsd      Float                @map("cost_usd")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  org          ResearchOrganization @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user         User                 @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt], map: "idx_org_ai_usage_created_at")
  @@index([orgId], map: "idx_org_ai_usage_org_id")
  @@index([userId], map: "idx_org_ai_usage_user_id")
  @@map("org_ai_usage")
}

/// Org admin'in araştırmacılara e-posta ile gönderdiği davet token'ları
model OrgInvitation {
  id        String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  orgId     String               @map("org_id")
  email     String
  token     String               @unique
  role      String               @default("researcher")
  expiresAt DateTime             @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime?            @map("used_at") @db.Timestamptz(6)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  org       ResearchOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_org_invitations_token")
  @@map("org_invitations")
}

/// AI model başına token maliyeti. Süper admin tarafından güncellenir.
model ModelPricing {
  id               String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  model            String   @unique
  displayName      String   @map("display_name")
  inputPricePer1k  Float    @map("input_price_per_1k")
  outputPricePer1k Float    @map("output_price_per_1k")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("model_pricing")
}

/// Admin tarafından yüklenen soru bankası havuzu
model PoolQuestion {
  id           String   @id @default(uuid())
  subject      String   /// Konu (örn. "Kardiyoloji")
  difficulty   String   @default("orta") /// "kolay" | "orta" | "zor"
  questionText String   @map("question_text") @db.Text
  options      Json     /// [{label: "A", text: "..."}, ...]
  correctAnswer String  @map("correct_answer") /// "A" | "B" | "C" | "D" | "E"
  explanation  String?  @db.Text
  tags         Json     @default("[]")
  source       String?  /// Upload batch ID or manual
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([subject])
  @@index([difficulty])
  @@map("pool_questions")
}

/// Admin tarafından yüklenen flashcard havuzu
model PoolFlashcard {
  id        String   @id @default(uuid())
  subject   String
  front     String   @db.Text
  back      String   @db.Text
  tags      Json     @default("[]")
  source    String?  /// Upload batch ID
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([subject])
  @@map("pool_flashcards")
}

// ─── EK MODELLER ─────────────────────────────────────────────────────────────

/// Admin tarafından oluşturulan kupon kodları.
model CouponCode {
  id           String    @id @default(uuid())
  code         String    @unique
  packageId    String    @map("package_id")
  durationDays Int?      @map("duration_days")
  maxUses      Int?      @map("max_uses")
  usedCount    Int       @default(0) @map("used_count")
  isActive     Boolean   @default(true) @map("is_active")
  expiresAt    DateTime? @map("expires_at")
  note         String?
  createdAt    DateTime  @default(now()) @map("created_at")

  package Package @relation(fields: [packageId], references: [id])

  @@map("coupon_codes")
}

model DocumentChunk {
  id        String                      @id @default(uuid())
  title     String
  branch    String
  content   String                      @db.Text
  embedding Unsupported("vector(768)")?
  metadata  Json?
  createdAt DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("document_chunks")
}

model StudentLearningProfile {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  topicMastery     Json      @default("{}") @map("topic_mastery")
  weakAreas        Json      @default("[]") @map("weak_areas")
  strongAreas      Json      @default("[]") @map("strong_areas")
  aiSummary        String?   @map("ai_summary")
  totalQuestions   Int       @default(0) @map("total_questions")
  totalCorrect     Int       @default(0) @map("total_correct")
  lastAnalyzedAt   DateTime  @default(now()) @map("last_analyzed_at")
  mentorInsights   Json?     @map("mentor_insights")
  motivationScore  Int?      @map("motivation_score")
  lastMentorChatAt DateTime? @map("last_mentor_chat_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_learning_profiles")
}

model DashboardPreferences {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  widgets   Json     @default("[]")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_preferences")
}

model StudySession {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  durationMin Int?      @map("duration_min")
  notes       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("study_sessions")
}

model QuestionAttempt {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  subject      String
  difficulty   String
  questionText String   @map("question_text")
  isCorrect    Boolean  @map("is_correct")
  attemptedAt  DateTime @default(now()) @map("attempted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subject])
  @@index([userId, attemptedAt])
  @@map("question_attempts")
}

model Deck {
  id        String      @id @default(uuid())
  name      String
  subject   String
  color     String
  cards     Flashcard[]
  createdAt DateTime    @default(now())
}

model Flashcard {
  id         String    @id @default(uuid())
  front      String    @db.Text
  back       String    @db.Text
  rating     String    @default("unknown")
  nextReview DateTime?
  deckId     String
  deck       Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

model ActivePlan {
  id        String   @id @default("user_active_plan")
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}

model UserAddonAccess {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  moduleKey       String    @map("module_key")
  reason          String?   @db.Text
  expiresAt       DateTime? @map("expires_at")
  grantedByUserId String?   @map("granted_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user          User  @relation("UserAddonAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("UserAddonAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, moduleKey])
  @@index([userId, expiresAt])
  @@map("user_addon_access")
}

model SupportTicket {
  id                  String               @id @default(uuid())
  userId              String               @map("user_id")
  subject             String
  category            String?
  status              String               @default("open")
  priority            String               @default("normal")
  adminNotes          String?              @map("admin_notes") @db.Text
  assignedAdminUserId String?              @map("assigned_admin_user_id")
  firstResponseAt     DateTime?            @map("first_response_at")
  lastResponseAt      DateTime?            @map("last_response_at")
  resolvedAt          DateTime?            @map("resolved_at")
  closedAt            DateTime?            @map("closed_at")
  closeReason         String?              @map("close_reason") @db.Text
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  user          User                @relation("SupportTicketOwner", fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin User?               @relation("SupportTicketAssignedAdmin", fields: [assignedAdminUserId], references: [id], onDelete: SetNull)
  messages      SupportTicketMessage[]
  notes         SupportTicketNote[]
  audits        SupportTicketAudit[]

  @@index([userId, createdAt])
  @@index([status, priority])
  @@index([assignedAdminUserId, status, updatedAt])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id           String        @id @default(uuid())
  ticketId     String        @map("ticket_id")
  authorUserId String        @map("author_user_id")
  body         String        @db.Text
  isAdmin      Boolean       @default(false) @map("is_admin")
  createdAt    DateTime      @default(now()) @map("created_at")

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUser User          @relation("SupportTicketMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([authorUserId, createdAt])
  @@map("support_ticket_messages")
}

model SupportTicketNote {
  id           String        @id @default(uuid())
  ticketId     String        @map("ticket_id")
  authorUserId String        @map("author_user_id")
  body         String        @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUser User          @relation("SupportTicketNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([authorUserId, createdAt])
  @@map("support_ticket_notes")
}

model SupportTicketAudit {
  id           String        @id @default(uuid())
  ticketId     String        @map("ticket_id")
  actorUserId  String?       @map("actor_user_id")
  action       String
  fromStatus   String?       @map("from_status")
  toStatus     String?       @map("to_status")
  details      String?       @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorUser User?         @relation("SupportTicketAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("support_ticket_audits")
}

model TokenWallet {
  id           String             @id @default(uuid())
  userId       String             @unique @map("user_id")
  balance      BigInt             @default(0)
  totalEarned  BigInt             @default(0) @map("total_earned")
  totalSpent   BigInt             @default(0) @map("total_spent")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TokenTransaction[]

  @@map("token_wallets")
}

model TokenTransaction {
  id           String      @id @default(uuid())
  walletId     String      @map("wallet_id")
  userId       String      @map("user_id")
  type         String
  amount       BigInt
  balanceAfter BigInt      @map("balance_after")
  description  String
  model        String?
  module       String?
  refId        String?     @map("ref_id")
  createdAt    DateTime    @default(now()) @map("created_at")

  wallet TokenWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([type])
  @@map("token_transactions")
}

model TokenPackage {
  id        String   @id @default(uuid())
  name      String
  tokens    BigInt
  bonusPct  Int      @default(0) @map("bonus_pct")
  priceTry  Float    @map("price_try")
  priceUsd  Float    @map("price_usd")
  isActive  Boolean  @default(true) @map("is_active")
  isPopular Boolean  @default(false) @map("is_popular")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("token_packages")
}

model ModuleActivity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  module    String
  action    String
  path      String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([module, createdAt])
  @@index([action, createdAt])
  @@map("module_activities")
}

model University {
  id            String               @id @default(uuid())
  name          String
  slug          String               @unique
  city          String?
  isActive      Boolean              @default(true) @map("is_active")
  createdAt     DateTime             @default(now()) @map("created_at")
  programs      Program[]
  emailDomains  UniversityEmailDomain[]
  academicProfiles UserAcademicProfile[]
  spaces        CommunitySpace[]
  resources     CommunityResource[]
  roleAssignments CommunityRoleAssignment[]
  bans          CommunityBan[]

  @@index([isActive])
  @@map("universities")
}

model UniversityEmailDomain {
  id           String     @id @default(uuid())
  universityId String     @map("university_id")
  domain       String     @unique
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId, isActive])
  @@map("university_email_domains")
}

model Program {
  id            String               @id @default(uuid())
  universityId  String               @map("university_id")
  name          String
  slug          String
  degreeType    String               @default("medicine") @map("degree_type")
  isActive      Boolean              @default(true) @map("is_active")
  createdAt     DateTime             @default(now()) @map("created_at")
  university    University           @relation(fields: [universityId], references: [id], onDelete: Cascade)
  terms         AcademicTerm[]
  courses       Course[]
  academicProfiles UserAcademicProfile[]
  spaces        CommunitySpace[]
  resources     CommunityResource[]
  roleAssignments CommunityRoleAssignment[]
  bans          CommunityBan[]

  @@unique([universityId, slug])
  @@index([universityId, isActive])
  @@map("programs")
}

model AcademicTerm {
  id            String               @id @default(uuid())
  programId     String               @map("program_id")
  name          String
  code          String
  sortOrder     Int                  @default(0) @map("sort_order")
  isActive      Boolean              @default(true) @map("is_active")
  createdAt     DateTime             @default(now()) @map("created_at")
  program       Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  courses       Course[]
  academicProfiles UserAcademicProfile[]
  spaces        CommunitySpace[]
  resources     CommunityResource[]
  roleAssignments CommunityRoleAssignment[]
  bans          CommunityBan[]

  @@unique([programId, code])
  @@index([programId, sortOrder])
  @@map("academic_terms")
}

model Course {
  id            String               @id @default(uuid())
  programId     String               @map("program_id")
  termId        String?              @map("term_id")
  name          String
  slug          String
  courseType    String               @default("course") @map("course_type")
  isActive      Boolean              @default(true) @map("is_active")
  createdAt     DateTime             @default(now()) @map("created_at")
  program       Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  term          AcademicTerm?        @relation(fields: [termId], references: [id], onDelete: SetNull)
  spaces        CommunitySpace[]
  resources     CommunityResource[]
  roleAssignments CommunityRoleAssignment[]
  bans          CommunityBan[]

  @@unique([programId, slug])
  @@index([programId, termId])
  @@map("courses")
}

model UserAcademicProfile {
  id                String       @id @default(uuid())
  userId            String       @unique @map("user_id")
  universityId      String?      @map("university_id")
  programId         String?      @map("program_id")
  termId            String?      @map("term_id")
  specialty         String?      @map("specialty")
  studentNoHash     String?      @map("student_no_hash")
  verificationStatus String      @default("pending") @map("verification_status")
  verifiedAt        DateTime?    @map("verified_at")
  visibilityLevel   String       @default("verified_only") @map("visibility_level")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  university        University?  @relation(fields: [universityId], references: [id], onDelete: SetNull)
  program           Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  term              AcademicTerm? @relation(fields: [termId], references: [id], onDelete: SetNull)

  @@index([universityId, programId, termId])
  @@index([verificationStatus])
  @@map("user_academic_profiles")
}

model CommunitySpace {
  id            String       @id @default(uuid())
  type          String
  title         String
  slug          String       @unique
  description   String?
  accessType    String       @default("public") @map("access_type")
  status        String       @default("active")
  universityId  String?      @map("university_id")
  programId     String?      @map("program_id")
  termId        String?      @map("term_id")
  courseId      String?      @map("course_id")
  ownerUserId   String?      @map("owner_user_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  university    University?  @relation(fields: [universityId], references: [id], onDelete: SetNull)
  program       Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  term          AcademicTerm? @relation(fields: [termId], references: [id], onDelete: SetNull)
  course        Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  ownerUser     User?        @relation("CommunitySpaceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  threads       CommunityThread[]
  resources     CommunityResource[]
  chats         CommunityGroupChat[]
  roleAssignments CommunityRoleAssignment[]

  @@index([type, status])
  @@index([universityId, programId, termId, courseId])
  @@map("community_spaces")
}

model CommunityThread {
  id              String       @id @default(uuid())
  spaceId         String       @map("space_id")
  authorId        String       @map("author_id")
  title           String
  description     String?
  contentType     String       @map("content_type")
  visibilityScope String       @default("global") @map("visibility_scope")
  status          String       @default("active")
  tags            Json         @default("[]")
  isPinned        Boolean      @default(false) @map("is_pinned")
  isLocked        Boolean      @default(false) @map("is_locked")
  containsSpoiler Boolean      @default(false) @map("contains_spoiler")
  bestAnswerPostId String?     @map("best_answer_post_id")
  attachedMaterialId String?   @map("attached_material_id")
  postCount       Int          @default(0) @map("post_count")
  reactionCount   Int          @default(0) @map("reaction_count")
  lastActivityAt  DateTime     @default(now()) @map("last_activity_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  space           CommunitySpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  author          User         @relation("CommunityThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  posts           CommunityPost[]

  @@index([spaceId, lastActivityAt])
  @@index([authorId, createdAt])
  @@index([contentType, status])
  @@map("community_threads")
}

model CommunityPost {
  id            String        @id @default(uuid())
  threadId       String       @map("thread_id")
  authorId       String       @map("author_id")
  body           String       @db.Text
  quotedPostId   String?      @map("quoted_post_id")
  status         String       @default("active")
  isBestAnswer   Boolean      @default(false) @map("is_best_answer")
  editSummary    Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  thread         CommunityThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author         User         @relation("CommunityPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  quotedPost     CommunityPost? @relation("CommunityPostQuote", fields: [quotedPostId], references: [id], onDelete: SetNull)
  replies        CommunityPost[] @relation("CommunityPostQuote")

  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
  @@map("community_posts")
}

model CommunityResource {
  id              String       @id @default(uuid())
  spaceId         String?      @map("space_id")
  authorId        String       @map("author_id")
  title           String
  description     String?
  resourceType    String       @default("file") @map("resource_type")
  visibilityScope String       @default("global") @map("visibility_scope")
  status          String       @default("active")
  url             String?
  filePath        String?      @map("file_path")
  linkedMaterialId String?     @map("linked_material_id")
  universityId    String?      @map("university_id")
  programId       String?      @map("program_id")
  termId          String?      @map("term_id")
  courseId        String?      @map("course_id")
  tags            Json         @default("[]")
  qualityScore    Int          @default(0) @map("quality_score")
  downloadCount   Int          @default(0) @map("download_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  space           CommunitySpace? @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  author          User         @relation("CommunityResourceAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  university      University?  @relation(fields: [universityId], references: [id], onDelete: SetNull)
  program         Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  term            AcademicTerm? @relation(fields: [termId], references: [id], onDelete: SetNull)
  course          Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([spaceId, createdAt])
  @@index([courseId, qualityScore])
  @@index([authorId, createdAt])
  @@map("community_resources")
}

model CommunityReaction {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  targetType   String    @map("target_type")
  targetId     String    @map("target_id")
  reactionType String    @map("reaction_type")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId, reactionType])
  @@index([targetType, targetId])
  @@map("community_reactions")
}

model CommunityBookmark {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  targetType String    @map("target_type")
  targetId   String    @map("target_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("community_bookmarks")
}

model CommunityFollow {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  targetType String    @map("target_type")
  targetId   String    @map("target_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("community_follows")
}

model CommunityGroupChat {
  id              String      @id @default(uuid())
  spaceId         String?     @map("space_id")
  createdByUserId String      @map("created_by_user_id")
  title           String
  description     String?
  isDirectMessage Boolean     @default(false) @map("is_direct_message")
  status          String      @default("active")
  lastMessageAt   DateTime?   @map("last_message_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  space           CommunitySpace? @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  createdByUser   User        @relation("CommunityChatCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  members         CommunityChatMember[]
  messages        CommunityChatMessage[]

  @@index([spaceId, status])
  @@index([isDirectMessage, lastMessageAt])
  @@map("community_group_chats")
}

model CommunityChatMember {
  id          String      @id @default(uuid())
  chatId       String     @map("chat_id")
  userId       String     @map("user_id")
  role         String     @default("member")
  status       String     @default("active")
  joinedAt     DateTime   @default(now()) @map("joined_at")
  lastReadAt   DateTime?  @map("last_read_at")
  mutedUntil   DateTime?  @map("muted_until")
  chat         CommunityGroupChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId, status])
  @@map("community_chat_members")
}

model CommunityChatMessage {
  id              String      @id @default(uuid())
  chatId          String      @map("chat_id")
  authorUserId    String      @map("author_user_id")
  body            String      @db.Text
  messageType     String      @default("text") @map("message_type")
  attachment      Json?
  replyToMessageId String?    @map("reply_to_message_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  chat            CommunityGroupChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  authorUser      User        @relation("CommunityChatMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  replyToMessage  CommunityChatMessage? @relation("CommunityChatReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies         CommunityChatMessage[] @relation("CommunityChatReply")
  reads           CommunityMessageRead[]

  @@index([chatId, createdAt])
  @@index([authorUserId, createdAt])
  @@map("community_chat_messages")
}

model CommunityMessageRead {
  id         String      @id @default(uuid())
  messageId  String      @map("message_id")
  userId     String      @map("user_id")
  readAt     DateTime    @default(now()) @map("read_at")
  message    CommunityChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@map("community_message_reads")
}

model CommunityReportReason {
  id          String     @id @default(uuid())
  key         String     @unique
  label       String
  description String?
  severity    String     @default("medium")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  reports     CommunityReport[]

  @@index([isActive, severity])
  @@map("community_report_reasons")
}

model CommunityReport {
  id                 String      @id @default(uuid())
  reporterUserId     String      @map("reporter_user_id")
  reasonId           String?     @map("reason_id")
  targetType         String      @map("target_type")
  targetId           String      @map("target_id")
  details            String?     @db.Text
  status             String      @default("open")
  assignedModeratorUserId String? @map("assigned_moderator_user_id")
  resolutionNotes    String?     @map("resolution_notes") @db.Text
  createdAt          DateTime    @default(now()) @map("created_at")
  resolvedAt         DateTime?   @map("resolved_at")
  reporterUser       User        @relation("CommunityReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reason             CommunityReportReason? @relation(fields: [reasonId], references: [id], onDelete: SetNull)
  assignedModerator  User?       @relation("CommunityReportModerator", fields: [assignedModeratorUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@map("community_reports")
}

model CommunityModerationAction {
  id            String    @id @default(uuid())
  actorUserId    String   @map("actor_user_id")
  targetType     String   @map("target_type")
  targetId       String   @map("target_id")
  targetUserId   String?  @map("target_user_id")
  actionType     String   @map("action_type")
  reason         String?  @db.Text
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  actorUser      User     @relation("CommunityModerationActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([actionType, createdAt])
  @@map("community_moderation_actions")
}

model CommunityRoleAssignment {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  role          String
  universityId  String?     @map("university_id")
  programId     String?     @map("program_id")
  termId        String?     @map("term_id")
  courseId      String?     @map("course_id")
  spaceId       String?     @map("space_id")
  grantedByUserId String?   @map("granted_by_user_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  expiresAt     DateTime?   @map("expires_at")
  user          User        @relation("CommunityRoleAssignee", fields: [userId], references: [id], onDelete: Cascade)
  university    University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
  program       Program?    @relation(fields: [programId], references: [id], onDelete: SetNull)
  term          AcademicTerm? @relation(fields: [termId], references: [id], onDelete: SetNull)
  course        Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  space         CommunitySpace? @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  grantedByUser User?       @relation("CommunityRoleGrantor", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, role])
  @@index([role, universityId, courseId])
  @@map("community_role_assignments")
}

model CommunityBlock {
  id            String    @id @default(uuid())
  blockerUserId String    @map("blocker_user_id")
  blockedUserId String    @map("blocked_user_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  blockerUser   User      @relation("CommunityBlocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blockedUser   User      @relation("CommunityBlocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId])
  @@map("community_blocks")
}

model CommunityMute {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  targetType    String    @map("target_type")
  targetId      String?   @map("target_id")
  mutedUserId   String?   @map("muted_user_id")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  user          User      @relation("CommunityMuteUser", fields: [userId], references: [id], onDelete: Cascade)
  mutedUser     User?     @relation("CommunityMutedUser", fields: [mutedUserId], references: [id], onDelete: SetNull)

  @@index([userId, targetType])
  @@map("community_mutes")
}

model CommunityBan {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  scopeType     String      @default("global") @map("scope_type")
  universityId  String?     @map("university_id")
  programId     String?     @map("program_id")
  termId        String?     @map("term_id")
  courseId      String?     @map("course_id")
  imposedByUserId String    @map("imposed_by_user_id")
  reason        String?     @db.Text
  status        String      @default("active")
  startsAt      DateTime    @default(now()) @map("starts_at")
  expiresAt     DateTime?   @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  user          User        @relation("CommunityBannedUser", fields: [userId], references: [id], onDelete: Cascade)
  university    University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
  program       Program?    @relation(fields: [programId], references: [id], onDelete: SetNull)
  term          AcademicTerm? @relation(fields: [termId], references: [id], onDelete: SetNull)
  course        Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  imposedByUser User        @relation("CommunityBanActor", fields: [imposedByUserId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([scopeType, expiresAt])
  @@map("community_bans")
}

model CommunityNotification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       String
  title      String
  body       String?
  href       String?
  isRead     Boolean   @default(false) @map("is_read")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("community_notifications")
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  category  String
  message   String
  details   String?  @db.Text
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([level])
  @@index([category])
  @@map("system_logs")
}
